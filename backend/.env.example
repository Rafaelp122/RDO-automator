# ==============================================================================
# RDO Automator Backend — Environment Variables (Exemplo)
# ==============================================================================

# Origens permitidas pelo CORS (separadas por vírgula)
# Adicione a URL do seu domínio personalizado do frontend quando configurar na Vercel
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://rdo-automator.rafaelpdev.com.br

# Limite máximo de upload em Megabytes (alinhado com o limite de 32MB do Cloud Run)
MAX_UPLOAD_MB=32

# Chave de segurança para as rotas da API (deixe vazia para desabilitar localmente)
API_KEY=dev-key

# Nível de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
